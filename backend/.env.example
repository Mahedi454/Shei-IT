# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/shei_it

# Admin access
ADMIN_EMAILS=admin@example.com

# Firebase Admin SDK JSON file path for local development
FIREBASE_SERVICE_ACCOUNT=./firebasadminsdk.json

# Firebase Admin SDK JSON as one line for hosting providers
FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase Admin SDK JSON encoded as Base64 for hosting providers
# PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("backend\firebasadminsdk.json")) | Set-Clipboard
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM=yourgmail@gmail.com
MAIL_TO=admin@example.com
