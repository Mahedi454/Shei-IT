generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PublishStatus {
  draft
  published
}

enum ContactStatus {
  new
  replied
  archived
}

model Blog {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  excerpt        String
  content        String
  coverImage     String?
  category       String        @default("General")
  authorName     String        @default("Shei IT Team")
  readTime       String?
  seoTitle       String?
  seoDescription String?
  featured       Boolean       @default(false)
  tags           String[]
  status         PublishStatus @default(draft)
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model SeoSetting {
  id              String   @id @default(cuid())
  seoableType     String   @map("seoable_type")
  seoableId       String   @map("seoable_id")
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  focusKeyword    String?  @map("focus_keyword")
  slug            String?
  canonicalUrl    String?  @map("canonical_url")
  ogTitle         String?  @map("og_title")
  ogDescription   String?  @map("og_description")
  ogImage         String?  @map("og_image")
  robotsIndex     Boolean  @default(true) @map("robots_index")
  robotsFollow    Boolean  @default(true) @map("robots_follow")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([seoableType, seoableId])
  @@map("seo_settings")
}

model Project {
  id                  String        @id @default(cuid())
  title               String
  slug                String        @unique
  description         String
  image               String
  categories          String[]
  metric              String?
  metricLabel         String?
  featured            Boolean       @default(false)
  eyebrow             String?
  type                String?
  liveUrl             String?
  clientRepositoryUrl String?
  serverRepositoryUrl String?
  overview            String?
  primaryOutcome      String?
  delivery            String?
  purpose             String?
  features            Json?
  accessRoles         Json?
  architectureSteps   Json?
  integrationCards    Json?
  techStack           Json?
  status              PublishStatus @default(draft)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Service {
  id                    String        @id @default(cuid())
  title                 String
  slug                  String        @unique
  cardDescription       String
  heroSummary           String
  heroDescription       String
  heroImageUrl          String?
  icon                  String
  accent                String
  offersTitle           String
  offersDescription     String
  reasonsTitle          String
  reasonsDescription    String
  processTitle          String
  processDescription    String
  technologyTitle       String
  technologyDescription String
  pricingTitle          String
  pricingDescription    String
  faqTitle              String
  ctaTitle              String
  ctaDescription        String
  stats                 Json
  offers                Json
  reasons               Json
  processSteps          Json
  technologies          Json
  pricingPackages       Json
  faqs                  Json
  sortOrder             Int           @default(0)
  status                PublishStatus @default(draft)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model Contact {
  id        String        @id @default(cuid())
  name      String
  email     String
  company   String?
  phone     String?
  service   String?
  budget    String?
  message   String
  status    ContactStatus @default(new)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
