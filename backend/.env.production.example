NODE_ENV=production

# Frontend origins allowed by CORS. Use comma-separated URLs with no trailing slash.
FRONTEND_URL=https://www.shei-it.com,https://shei-it.com

# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Admin auth
ADMIN_EMAILS=sheiitofficial@gmail.com

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=sheiitofficial@gmail.com
