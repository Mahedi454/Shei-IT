NODE_ENV=production

# Frontend origins allowed by CORS. Use comma-separated URLs with no trailing slash.
FRONTEND_URL=https://www.shei-it.com,https://shei-it.com

# PostgreSQL — for Neon, use the POOLED host (the one containing "-pooler").
# The trailing params keep the connection resilient to Neon idle/cold-starts:
#   connect_timeout=30  wait out a cold start instead of failing with P1001
#   pool_timeout=30     wait for a pooled connection under load
#   pgbouncer=true      required for Neon's pooled (PgBouncer) endpoint
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.REGION.aws.neon.tech/database?sslmode=require&channel_binding=require&connect_timeout=30&pool_timeout=30&pgbouncer=true

# Admin auth
ADMIN_EMAILS=sheiitofficial@gmail.com

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=sheiitofficial@gmail.com
